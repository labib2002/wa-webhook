# =============================================================================
#  wa-webhook / Agent Inbox — environment variables
#  Copy to .env for local dev:  cp .env.example .env   (then fill in values)
#  Set the SAME variables in Vercel: Project → Settings → Environment Variables.
#  NEVER commit your real .env — it is gitignored.
# =============================================================================

# --- Meta webhook verification (existing, unchanged) -------------------------
# Must match the "Verify token" you enter in the Meta webhook config.
VERIFY_TOKEN=vibecode123

# --- WhatsApp send channel (Graph API) ---------------------------------------
# Meta dashboard → WhatsApp → API Setup.
# WHATSAPP_TOKEN is the temporary ~24h token on that page; swap it for a
# permanent System User token later (see README "Tokens").
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
# Graph API version to call. Pinned so behavior is stable; bump when you choose.
GRAPH_API_VERSION=v23.0

# --- Webhook signature verification ------------------------------------------
# Meta dashboard → App Settings → Basic → "App secret" (click Show).
# If left blank, signature verification is SKIPPED (allowed, but recommended to set).
APP_SECRET=

# --- Supabase (database) -----------------------------------------------------
# Supabase → Project Settings → API.
# SUPABASE_URL: "Project URL".  SERVICE_ROLE_KEY: the secret key (server-only,
# full access — NEVER expose to the browser). Either the new `sb_secret_…` key
# or the legacy `service_role` JWT works.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Private Storage bucket for incoming WhatsApp media. Create it once with:
#   node scripts/setup-storage.js
MEDIA_BUCKET=wa-media

# --- Dashboard access gate ---------------------------------------------------
# DASHBOARD_PASSCODE: the single shared passcode agents type to log in.
# SESSION_SECRET: a long random string used to sign the session cookie.
#   Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_PASSCODE=
SESSION_SECRET=

# --- Service send API (machine callers, /api/service/*) ----------------------
# Token the ops backend sends as x-service-token. Unset = that surface is off.
SERVICE_SEND_TOKEN=
# Comma-separated template allow-list for send-template.
# Empty = only template names matching ops_* are allowed.
WA_TEMPLATE_ALLOWLIST=

# --- Retention & limits (daily GET /api/cron/maintenance) ---------------------
# Auth for the cron endpoint. Vercel sends "Authorization: Bearer <CRON_SECRET>"
# automatically on cron invocations once this is set in the project env.
# If unset, the endpoint requires x-service-token (SERVICE_SEND_TOKEN) instead.
CRON_SECRET=
# Delete stored media BYTES older than N days (rows flip to media_status
# 'expired'; message text and conversations are never deleted). 0 = disabled.
MEDIA_RETENTION_DAYS=90
# Usage alert caps: the cron alerts above 70% of either cap.
MEDIA_CAP_MB=1000
MESSAGES_CAP_ROWS=400000
# WhatsApp number (international digits, e.g. 2010xxxxxxxx) that receives the
# usage alert text. Empty = no alert is ever sent.
WA_USAGE_ALERT_TO=
